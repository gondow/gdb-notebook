{
  "scopeName": "source.gdb",
  "patterns": [
    {
      "match": "\\b(b|bt|c|comm|d|do|dis|disas|disp|en|f|fin|i|if|j|l|n|ni|p|pt|q|r|rb|s|si|tb|wa|wha|break|if|run|continue|info|print|x|quit|step|next|stepi|nexti|finish|display|until|list|disable|enable|delete|commands|tbreak|rbreak|watch|backtrace|end|up|down|frame|printf|dprintf|return|jump|compile|disassemble|whatis|ptype)\\b",
      "name": "keyword.control.gdb"
    },
    {
      "match": "#.*$",
      "name": "comment.line.number-sign.gdb"
    },
    {
      "match": "^\\(gdb\\)|>",
      "name": "support.function.gdb"
    }
  ]
}