{
  "scopeName": "source.gdb",
  "patterns": [
    {
      "match": "\\b(if|b|r|c|i|p|q|s|n|si|ni|fin|disp|dis|en|d|break|if|run|continue|info|print|x|quit|step|next|stepi|nexti|finish|display|until|list|disable|enable|delete)\\b",
      "name": "keyword.control.gdb"
    },
    {
      "match": "#.*$",
      "name": "comment.line.number-sign.gdb"
    },
    {
      "match": "^\\(gdb\\)",
      "name": "support.function.gdb"
    }
  ]
}