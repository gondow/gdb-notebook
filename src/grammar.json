// JSON5 データ（コメント，ケツカンマ，文字列中での改行あり）
{
    // GDBコマンド用のデータ
    "gdb_command": {
	aliasMap: {
	    if: "if",  // これだけ特別
	    b: "break",
	    r: "run",
	    c: "continue"
	},
	commandMap: {
	    break: {
		exp: "break: 指定した場所にブレークポイント（実行の一時停止場所）を設定する",
		abbr: "b",
		usage: [["break main",      "main関数の先頭にブレークポインタを設定"],
			["break file.c:10", "ファイルfile.cの10行目にブレークを設定"],
			["break 42",        "（現在のファイルの）42行目にブレークポイントを設定"]],
		url: "https://gondow.github.io/linux-x86-64-programming/10-gdb.html#%E5%A4%89%E6%95%B0%E3%81%AE%E5%80%A4%E3%82%92%E8%A1%A8%E7%A4%BA-print",
	    },
	    if: {
		exp: "break &lt;場所&gt; if &lt;条件&gt;: 条件付きブレークポイントを設定する",
		abbr: "無し",
		usage: [["break fact if n==0", "変数nが0に等しいときだけ，fact関数の先頭で実行を一時停止するブレークポイントを設定"]],
		url: "https://gondow.github.io/linux-x86-64-programming/10-gdb.html#%E6%9D%A1%E4%BB%B6%E4%BB%98%E3%81%8D%E3%83%96%E3%83%AC%E3%83%BC%E3%82%AF%E3%83%9D%E3%82%A4%E3%83%B3%E3%83%88%E3%81%AE%E8%A8%AD%E5%AE%9A%E3%81%A8%E3%83%90%E3%83%83%E3%82%AF%E3%83%88%E3%83%AC%E3%83%BC%E3%82%B9%E8%A1%A8%E7%A4%BA-break-if-backtrace",
	    },
	    run: {
		exp: "run: gdb上で（デバッグ対象の）プログラムの実行を開始する",
		abbr: "r",
		usage: [["run", "プログラムの実行開始"],
			["run a b c", "コマンドライン引数 a b c を与えて実行開始"],
			["run < foo.txt", "標準入力をファイルfoo.txtに切り替えて（リダイレクトして）実行開始"]],
		url: "https://gondow.github.io/linux-x86-64-programming/10-gdb.html#%E8%B5%B7%E5%8B%95-run-%E3%81%A8%E7%B5%82%E4%BA%86-quit",
	    },
	    continue: {
		exp: "continue: （ブレークで一時停止中の）プログラムの実行を再開する",
		abbr: "c",
		usage: [["continue", "プログラムの実行再開"]],
		url: "https://gondow.github.io/linux-x86-64-programming/10-gdb.html#%E5%AE%9F%E8%A1%8C%E5%86%8D%E9%96%8B%E3%81%AE%E5%AE%9F%E8%A1%8C%E4%BE%8B-continue",
	    },
	},
    },
    // シェルコマンド用のデータ（省略コマンドは無し）
    shell_command: {
	commandMap: {
	    ls: {
		exp: "ls: （現在居るディレクトリにある）ファイル一覧を表示する",
		usage: [["ls", "ファイル一覧を表示"],
			["ls -l", "ロングフォーマットで表示"],
			["ls -a", "隠しファイル（.で始まるファイル）も表示"]],
		url: "https://www.tohoho-web.com/linux/cmd/ls.html",
	    },
	    gcc: {
		exp: "gcc: （C言語等の）プログラムをコンパイルする",
		usage: [["gcc foo.c", "foo.c をコンパイルして，実行可能ファイル a.out を生成する"],
			["gcc -g foo.c", "foo.c をコンパイルして，デバッグ情報付きの実行可能ファイル a.out を生成する"],
			["gcc -c foo.c", "foo.c をコンパイルして，オブジェクトファイル foo.o を生成する"]],
		url: "https://www.tohoho-web.com/ex/c-lang.html#hello-world",
	    },
	    gdb: {
		exp: "gdb: コマンドライン引数に指定したプログラムをデバッグ対象としてgdbを起動する",
		usage: [["gdb ./a.out", "./a.out をデバッグ対象として，gdbを起動する"],
			["gdb -p 1234", "実行中のプロセス（プロセス番号1234）に接続して，gdbを起動する"]],
		url: "https://www.tohoho-web.com/ex/c-lang.html#hello-world",
	    },
	},
    },
}
