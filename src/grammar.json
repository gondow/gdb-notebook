// JSON5 データ（コメント，ケツカンマ，文字列中での改行あり）
{
    // GDBコマンド用のデータ
    "gdb_command": {
	aliasMap: {
	    b: "break",
	    r: "run",
	    c: "continue"
	},
	commandMap: {
	    break: {
		exp: "ブレークポイントを設定する",
		usage: "break main         # main関数でブレーク\
b main             # 省略コマンド\
break file.c:10    # ファイルfile.cの10行目でブレーク\
break 42           # （現在のファイルの）42行目でブレーク",
		url: "https://gondow.github.io/linux-x86-64-programming/10-gdb.html#%E5%A4%89%E6%95%B0%E3%81%AE%E5%80%A4%E3%82%92%E8%A1%A8%E7%A4%BA-print",
	    },
	    run: {
		exp: "gdb上で（デバッグ対象の）プログラムの実行を開始する",
		usage: "run            # プログラムの実行開始\
r              # 省略コマンド\
run a b c      # コマンドライン引数 a b c を与えて実行開始\
run < foo.txt  # 標準入力をファイルfoo.txtに切り替えて（リダイレクトして）実行開始",
		url: "https://gondow.github.io/linux-x86-64-programming/10-gdb.html#%E8%B5%B7%E5%8B%95-run-%E3%81%A8%E7%B5%82%E4%BA%86-quit",
	    },
	    continue: {
		exp: "（ブレークで一時停止中の）プログラムの実行を再開する",
		usage: "continue        # プログラムの実行開始\
c               # 省略コマンド",
		url: "https://gondow.github.io/linux-x86-64-programming/10-gdb.html#%E5%AE%9F%E8%A1%8C%E5%86%8D%E9%96%8B%E3%81%AE%E5%AE%9F%E8%A1%8C%E4%BE%8B-continue",
	    },
	},
    },
    // シェルコマンド用のデータ（省略コマンドは無し）
    shell_command: {
	commandMap: {
	    ls: {
		exp: "（現在居るディレクトリにある）ファイル一覧を表示する",
		usage: "ls      # ファイル一覧を表示\
ls -l      # ロングフォーマットで表示\
ls -a      # 隠しファイル（.で始まるファイル）も表示",
		url: "https://www.tohoho-web.com/linux/cmd/ls.html",
	    },
	    gcc: {
		exp: "（C言語等の）プログラムをコンパイルする",
		usage: "gcc foo.c      # foo.c をコンパイルして，実行可能ファイル a.out を生成する\
gcc -g foo.c   # foo.c をコンパイルして，デバッグ情報付きの実行可能ファイル a.out を生成する\
gcc -c foo.c   # foo.c をコンパイルして，オブジェクトファイル foo.o を生成する",
		url: "https://www.tohoho-web.com/ex/c-lang.html#hello-world",
	    },
	    gdb: {
		exp: "コマンドライン引数に指定したプログラムをデバッグ対象としてgdbを起動する",
		usage: "gdb ./a.out    # ./a.out をデバッグ対象として，gdbを起動する\
gdb -p 12345   # 実行中のプロセス（プロセス番号12345）に接続して，gdbを起動する",
		url: "https://www.tohoho-web.com/ex/c-lang.html#hello-world",
	    },
	},
    },
}
