{
    "publisher": "gondow",
    "name": "gdb-notebook",
    "displayName": "gdb-notebook",
    "description": "gdb-notebook",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onNotebook:gdb-notebook"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "gdb-notebook.helloWorld",
                "title": "Hello World"
            },
            {
                "command": "gdb-notebook.restartGdbTerminal",
                "title": "Restart GDBNB terminal",
                "icon": "$(debug-restart)"
            },
            {
                "command": "gdb-notebook.showHelp",
                "title": "show help"
            },
            {
                "command": "gdb-notebook.showLink",
                "title": "show link"
            },
            {
                "command": "example.quickpick",
                "title": "Example QuickPick"
            }
        ],
        "notebooks": [
            {
                "type": "gdb-notebook",
                "displayName": "GDB Notebook",
                "selector": [
                    {
                        "filenamePattern": "*.gdbnb"
                    }
                ]
            }
        ],
        "notebookSerializer": [
            {
                "type": "gdb-notebook",
                "displayName": "GDB Notebook Serializer"
            }
        ],
        "menus": {
            "notebook/toolbar": [
                {
                    "command": "gdb-notebook.restartGdbTerminal",
                    "when": "notebookType == 'gdb-notebook'",
                    "group": "navigation@1"
                }
            ]
        },
        "languages": [
            {
                "id": "gdb_command",
                "aliases": [
                    "GDB command"
                ],
                "configuration": "./lang-config.json"
            },
            {
                "id": "extension_command",
                "aliases": [
                    "extension command"
                ],
                "configuration": "./lang-config.json"
            }
        ],
        "grammars": [
            {
                "language": "gdb_command",
                "scopeName": "source.gdb",
                "path": "./gdb.tmGrammar.json"
            },
            {
                "language": "extension_command",
                "scopeName": "source.extension",
                "path": "./extension.tmGrammar.json"
            }
        ],
        "views": {
            "explorer": [
                {
                    "type": "webview",
                    "id": "commandHelpView",
                    "name": "GDBNBコマンドヘルプ"
                },
                {
                    "id": "commandTreeView",
                    "name": "GDBNBコマンドリスト"
                }
            ]
        },
        "configuration": {
            "type": "object",
            "title": "GDB Notebook",
            "properties": {
                "gdbDemo.showDemo": {
                    "type": "boolean",
                    "default": true,
                    "description": "次回から送信デモを表示するかどうか"
                },
                "gdbDemo.showDemo2": {
                    "type": "string",
                    "default": "hogehoge",
                    "description": "sample value"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./"
    },
    "devDependencies": {
        "@types/node": "22.x",
        "@types/vscode": "^1.110.0",
        "source-map-support": "^0.5.21",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "json5": "^2.2.3"
    }
}
