{
  "name": "gdb-notebook-dev",
  "image": "mcr.microsoft.com/devcontainers/cpp:0-ubuntu-22.04",

  "customizations": {
    "vscode": {
      "extensions": [
        "gondow.gdb-notebook"
      ]
    }
  },

  "postCreateCommand": "cp .devcontainer/.gdbinit ~/.gdbinit || true",

  "containerEnv": {
    "DEBUGINFOD_URLS": ""
  }
}
